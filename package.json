{
  "name": "rundock",
  "version": "0.8.2",
  "description": "A browser-based OS for AI agent teams. Built for knowledge work, powered by Claude Code.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "update": "git pull origin main && npm install && echo '\\n  Rundock updated. Run: npm start'",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "dist": "node scripts/build.js",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-updater": "^6.6.0",
    "marked": "^17.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "ai.rundock.app",
    "productName": "Rundock",
    "directories": {
      "output": "/tmp/rundock-dist"
    },
    "files": [
      "server.js",
      "public/**/*",
      "scaffold/**/*",
      "node_modules/**/*",
      "electron/**/*",
      "package.json"
    ],
    "icon": "electron/build/icon.icns",
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "electron/build/entitlements.mac.plist",
      "entitlementsInherit": "electron/build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Rundock",
      "window": {
        "width": 660,
        "height": 400
      },
      "backgroundColor": "#F2F1EF",
      "iconSize": 120,
      "iconTextSize": 11,
      "contents": [
        {
          "x": 165,
          "y": 185,
          "type": "file"
        },
        {
          "x": 495,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "liamdarmody",
      "repo": "rundock"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true
}
