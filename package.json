{
  "name": "rundock",
  "version": "0.9.2",
  "description": "A visual interface for AI agent teams. Built for people running their own businesses, powered by Claude Code.",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test $(find test -name '*.test.js')",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=server.js --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage.lcov $(find test -name '*.test.js') && node test/tools/coverage-areas.js coverage.lcov",
    "update": "git pull origin main && npm install && echo '\\n  Rundock updated. Run: npm start'",
    "electron": "electron .",
    "build:mac": "electron-builder --mac",
    "dist": "node scripts/build.js",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "electron-updater": "^6.6.0",
    "marked": "^17.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "ai.rundock.app",
    "productName": "Rundock",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "public/**/*",
      "scaffold/**/*",
      "scripts/**/*",
      "node_modules/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "scripts/**/*"
    ],
    "icon": "electron/build/icon.icns",
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "electron/build/entitlements.mac.plist",
      "entitlementsInherit": "electron/build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Rundock",
      "window": {
        "width": 660,
        "height": 400
      },
      "backgroundColor": "#F2F1EF",
      "iconSize": 120,
      "iconTextSize": 11,
      "contents": [
        {
          "x": 165,
          "y": 185,
          "type": "file"
        },
        {
          "x": 495,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "electron/build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "Rundock-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Rundock-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "liamdarmody",
      "repo": "rundock"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "SEE LICENSE IN LICENSE",
  "private": true
}
